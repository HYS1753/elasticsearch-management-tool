# Cluster API Configuration
CLUSTER_API_URL=http://localhost:8000

# Application Configuration
NEXT_PUBLIC_APP_NAME=Elasticsearch Management Tool
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_PORT=3000
NEXT_PUBLIC_APP_COOKIE_SECURE=false

# Environment Profile (dev | stg | prod)
NEXT_PUBLIC_APP_PROFILE=dev

# JWT 세션 콠키 만료 시간 (단위: 시간, 백엔드 API의 JWT_ACCESS_TOKEN_EXPIRE_HOURS 값과 일치시켜야 합니다)
NEXT_PUBLIC_AUTH_TOKEN_EXPIRE_HOURS=24
